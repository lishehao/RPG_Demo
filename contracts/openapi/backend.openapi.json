{
  "components": {
    "schemas": {
      "AdminLoginRequest": {
        "properties": {
          "email": {
            "maxLength": 320,
            "minLength": 3,
            "title": "Email",
            "type": "string"
          },
          "password": {
            "maxLength": 256,
            "minLength": 1,
            "title": "Password",
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "title": "AdminLoginRequest",
        "type": "object"
      },
      "AdminLoginResponse": {
        "properties": {
          "access_token": {
            "title": "Access Token",
            "type": "string"
          },
          "token": {
            "title": "Token",
            "type": "string"
          },
          "token_type": {
            "const": "bearer",
            "default": "bearer",
            "title": "Token Type",
            "type": "string"
          }
        },
        "required": [
          "token",
          "access_token"
        ],
        "title": "AdminLoginResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "SessionAction": {
        "properties": {
          "id": {
            "title": "Id",
            "type": "string"
          },
          "label": {
            "title": "Label",
            "type": "string"
          }
        },
        "required": [
          "id",
          "label"
        ],
        "title": "SessionAction",
        "type": "object"
      },
      "SessionCreateRequest": {
        "properties": {
          "story_id": {
            "minLength": 1,
            "title": "Story Id",
            "type": "string"
          }
        },
        "required": [
          "story_id"
        ],
        "title": "SessionCreateRequest",
        "type": "object"
      },
      "SessionCreateResponse": {
        "properties": {
          "session_id": {
            "title": "Session Id",
            "type": "string"
          }
        },
        "required": [
          "session_id"
        ],
        "title": "SessionCreateResponse",
        "type": "object"
      },
      "SessionGetResponse": {
        "properties": {
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "session_id": {
            "title": "Session Id",
            "type": "string"
          },
          "state": {
            "enum": [
              "active",
              "completed"
            ],
            "title": "State",
            "type": "string"
          },
          "story_id": {
            "title": "Story Id",
            "type": "string"
          }
        },
        "required": [
          "session_id",
          "story_id",
          "created_at",
          "state"
        ],
        "title": "SessionGetResponse",
        "type": "object"
      },
      "SessionHistoryResponse": {
        "properties": {
          "history": {
            "items": {
              "$ref": "#/components/schemas/SessionHistoryTurn"
            },
            "title": "History",
            "type": "array"
          }
        },
        "title": "SessionHistoryResponse",
        "type": "object"
      },
      "SessionHistoryTurn": {
        "properties": {
          "actions": {
            "items": {
              "$ref": "#/components/schemas/SessionAction"
            },
            "title": "Actions",
            "type": "array"
          },
          "narration": {
            "title": "Narration",
            "type": "string"
          },
          "turn": {
            "minimum": 1.0,
            "title": "Turn",
            "type": "integer"
          }
        },
        "required": [
          "turn",
          "narration"
        ],
        "title": "SessionHistoryTurn",
        "type": "object"
      },
      "SessionStepRequest": {
        "properties": {
          "free_text": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Free Text"
          },
          "move_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Move Id"
          }
        },
        "title": "SessionStepRequest",
        "type": "object"
      },
      "SessionStepResponse": {
        "properties": {
          "actions": {
            "items": {
              "$ref": "#/components/schemas/SessionAction"
            },
            "title": "Actions",
            "type": "array"
          },
          "narration": {
            "title": "Narration",
            "type": "string"
          },
          "risk_hint": {
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "title": "Risk Hint",
            "type": "string"
          },
          "turn": {
            "minimum": 1.0,
            "title": "Turn",
            "type": "integer"
          }
        },
        "required": [
          "turn",
          "narration",
          "risk_hint"
        ],
        "title": "SessionStepResponse",
        "type": "object"
      },
      "StoryGenerateRequest": {
        "properties": {
          "difficulty": {
            "maxLength": 40,
            "minLength": 1,
            "title": "Difficulty",
            "type": "string"
          },
          "theme": {
            "maxLength": 120,
            "minLength": 1,
            "title": "Theme",
            "type": "string"
          }
        },
        "required": [
          "theme",
          "difficulty"
        ],
        "title": "StoryGenerateRequest",
        "type": "object"
      },
      "StoryGenerateResponse": {
        "properties": {
          "published": {
            "title": "Published",
            "type": "boolean"
          },
          "story_id": {
            "title": "Story Id",
            "type": "string"
          },
          "title": {
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "story_id",
          "title",
          "published"
        ],
        "title": "StoryGenerateResponse",
        "type": "object"
      },
      "StoryListItem": {
        "properties": {
          "story_id": {
            "title": "Story Id",
            "type": "string"
          },
          "title": {
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "story_id",
          "title"
        ],
        "title": "StoryListItem",
        "type": "object"
      },
      "StoryListResponse": {
        "properties": {
          "stories": {
            "items": {
              "$ref": "#/components/schemas/StoryListItem"
            },
            "title": "Stories",
            "type": "array"
          }
        },
        "title": "StoryListResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "title": "RPG Mock Backend",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
