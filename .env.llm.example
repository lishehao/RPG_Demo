APP_DATABASE_URL=sqlite:///./app.db
# Auth (required in prod; defaults here are dev-only)
APP_AUTH_JWT_SECRET=dev-only-change-me
APP_AUTH_JWT_EXPIRE_MINUTES=480
APP_AUTH_JWT_ISSUER=rpg-backend
APP_ADMIN_BOOTSTRAP_EMAIL=admin@example.com
APP_ADMIN_BOOTSTRAP_PASSWORD=admin123456
APP_INTERNAL_WORKER_TOKEN=dev-worker-token
APP_LLM_OPENAI_BASE_URL=https://your-openai-compatible-endpoint
APP_LLM_OPENAI_API_KEY=replace-with-your-key
APP_LLM_OPENAI_MODEL=replace-with-your-default-model
# Worker upstream format is configurable: APP_LLM_WORKER_UPSTREAM_API_FORMAT=chat_completions|responses
# Model resolution:
# route_model = APP_LLM_OPENAI_ROUTE_MODEL or APP_LLM_OPENAI_MODEL
# narration_model = APP_LLM_OPENAI_NARRATION_MODEL or APP_LLM_OPENAI_MODEL
# generator_model = APP_LLM_OPENAI_GENERATOR_MODEL or APP_LLM_OPENAI_MODEL
# If APP_LLM_OPENAI_MODEL is set, any unset specialized model inherits it.
# If APP_LLM_OPENAI_MODEL is empty, set ROUTE + NARRATION + GENERATOR models explicitly.
APP_LLM_OPENAI_ROUTE_MODEL=
APP_LLM_OPENAI_NARRATION_MODEL=
APP_LLM_OPENAI_GENERATOR_MODEL=

# Optional tuning knobs
APP_LLM_OPENAI_TIMEOUT_SECONDS=20
APP_LLM_OPENAI_ROUTE_MAX_RETRIES=3
APP_LLM_OPENAI_NARRATION_MAX_RETRIES=1
APP_LLM_OPENAI_TEMPERATURE_ROUTE=0.1
APP_LLM_OPENAI_TEMPERATURE_NARRATION=0.4
APP_LLM_OPENAI_GENERATOR_TEMPERATURE=0.15
APP_LLM_OPENAI_GENERATOR_MAX_RETRIES=3
APP_GENERATOR_CANDIDATE_PARALLELISM=1

# Backend always calls worker-only gateway.
APP_LLM_WORKER_BASE_URL=http://127.0.0.1:8100
APP_LLM_WORKER_UPSTREAM_API_FORMAT=chat_completions
APP_LLM_WORKER_TIMEOUT_SECONDS=20
APP_LLM_WORKER_CONNECT_TIMEOUT_SECONDS=5
APP_LLM_WORKER_MAX_CONNECTIONS=100
APP_LLM_WORKER_MAX_KEEPALIVE_CONNECTIONS=20
APP_LLM_WORKER_HTTP2_ENABLED=false
APP_LLM_WORKER_DEFAULT_RPM=300
APP_LLM_WORKER_DEFAULT_TPM=600000
APP_LLM_WORKER_MODEL_LIMITS_JSON={}
APP_LLM_WORKER_QUEUE_MAX_SIZE=1024
APP_LLM_WORKER_QUEUE_WAIT_TIMEOUT_SECONDS=8
APP_LLM_WORKER_QUEUE_WEIGHTS_JSON={"route_intent":5,"render_narration":3,"json_object":2}
APP_LLM_WORKER_EXECUTOR_CONCURRENCY=16
APP_LLM_WORKER_TOKEN_EST_ROUTE_OUTPUT=96
APP_LLM_WORKER_TOKEN_EST_NARRATION_OUTPUT=192
APP_LLM_WORKER_TOKEN_EST_JSON_OUTPUT=256

# Observability
APP_OBS_LOG_LEVEL=INFO
APP_OBS_REQUEST_ID_HEADER=X-Request-ID
APP_OBS_REDACT_INPUT_TEXT=true
APP_OBS_ALERT_WEBHOOK_URL=
APP_OBS_ALERT_WINDOW_SECONDS=300
APP_OBS_ALERT_BUCKET_MIN_COUNT=3
APP_OBS_ALERT_BUCKET_MIN_SHARE=0.10
APP_OBS_ALERT_GLOBAL_ERROR_RATE=0.05
APP_OBS_ALERT_COOLDOWN_SECONDS=900
APP_OBS_ALERT_HTTP_5XX_RATE=0.05
APP_OBS_ALERT_HTTP_5XX_MIN_COUNT=10
APP_OBS_ALERT_READY_FAIL_STREAK=2
APP_OBS_ALERT_WORKER_FAIL_RATE=0.05
APP_OBS_ALERT_WORKER_FAIL_MIN_COUNT=20
APP_OBS_ALERT_LLM_CALL_P95_MS=3000
APP_OBS_ALERT_LLM_CALL_MIN_COUNT=30

# Readiness probe
APP_READY_LLM_PROBE_ENABLED=true
APP_READY_LLM_PROBE_CACHE_TTL_SECONDS=30
APP_READY_LLM_PROBE_TIMEOUT_SECONDS=5
