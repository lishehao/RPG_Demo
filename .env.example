APP_STORY_LIBRARY_DB_PATH=artifacts/story_library.sqlite3
APP_RUNTIME_STATE_DB_PATH=artifacts/runtime_state.sqlite3
APP_PLAY_SESSION_TTL_SECONDS=3600
APP_ENABLE_BENCHMARK_API=0
APP_AUTH_SESSION_COOKIE_SECURE=false
APP_AUTH_SESSION_COOKIE_SAMESITE=lax
APP_LOCAL_PORTRAIT_BASE_URL=http://127.0.0.1:8000

# Primary generation gateway for author / play / benchmark agents.
# The same base/key/model can be used via responses or chat_completions;
# the caller script or gateway entrypoint chooses the transport.
APP_GATEWAY_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
APP_GATEWAY_API_KEY=replace_me
APP_GATEWAY_MODEL=qwen3.5-flash
# Optional: override only play.* capabilities.
# APP_GATEWAY_PLAY_MODEL=qwen3.5-plus
# Optional: override only the responses transport endpoint when it differs from chat_completions.
# APP_GATEWAY_RESPONSES_BASE_URL=https://dashscope-us.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1

# Optional generation tuning.
# APP_GATEWAY_TIMEOUT_SECONDS=20
# APP_GATEWAY_TIMEOUT_SECONDS_AUTHOR=120
# APP_GATEWAY_TIMEOUT_SECONDS_BENCHMARK_DRIVER=90
# APP_GATEWAY_USE_SESSION_CACHE=false

# Optional helper agent gateway for internal benchmark / UI-agent helper calls.
# This stays isolated from the primary author / play runtime gateway.
# APP_HELPER_GATEWAY_BASE_URL=https://api.openai.com/v1
# APP_HELPER_GATEWAY_API_KEY=replace_me
# APP_HELPER_GATEWAY_MODEL=gpt-5-mini
# APP_HELPER_GATEWAY_RESPONSES_BASE_URL=https://api.openai.com/v1

# Character roster runtime.
APP_ROSTER_ENABLED=true
APP_ROSTER_SOURCE_CATALOG_PATH=data/character_roster/catalog.json
APP_ROSTER_RUNTIME_CATALOG_PATH=artifacts/character_roster_runtime.json
APP_ROSTER_MAX_SUPPORTING_CAST_SELECTIONS=3

# Optional Postgres + pgvector knowledge layer.
# When enabled, author retrieval can source candidates from Postgres instead of runtime JSON.
# APP_CHARACTER_KNOWLEDGE_ENABLED=false
# APP_CHARACTER_KNOWLEDGE_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/rpg_demo
# APP_CHARACTER_KNOWLEDGE_SOURCE_KIND=roster_catalog
# APP_CHARACTER_KNOWLEDGE_CANDIDATE_LIMIT=24

# Character roster embedding retrieval stays independent.
APP_GATEWAY_EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
APP_GATEWAY_EMBEDDING_API_KEY=replace_me
APP_GATEWAY_EMBEDDING_MODEL=gemini-embedding-001

# Local portrait batch generation
# PORTRAIT_IMAGE_API_KEY=replace_me
